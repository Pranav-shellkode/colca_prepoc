# Backend base URL and WebSocket endpoint
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws

# Dev-only: matches backend's BACKEND_API_KEY (see backend/core/config.py).
# The /calls* endpoints are meant to be called by a trusted upstream server,
# not the browser directly — shipping this key to the client is fine for
# local development but must move behind a backend-for-frontend before any
# real deployment, since anything sent to the browser is public.
VITE_API_KEY=